  letter-spacing: 0.16em;
  opacity: 1;
  color: rgba(255, 255, 255, 0.4) !important;
  text-transform: uppercase;
}

.vkId {
  font-size: 14px;
  letter-spacing: 0.05em;
  opacity: 1;
  color: var(--glass-border) !important;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace;
}

.card.light .frontFace .brand,
.card.light .frontFace .name,
.card.light .frontFace .status,
.card.light .frontFace .vkId,
.card.dark .frontFace .brand,
.card.dark .frontFace .name,
.card.dark .frontFace .status,
.card.dark .frontFace .vkId {
  color: inherit;
}


.grain,
.sweep {
  display: none !important;
}

.glare {
  position: absolute;
  inset: -15%;
  border-radius: inherit;
  pointer-events: none;
  z-index: 3;
  opacity: 0;
  mix-blend-mode: screen;
  filter: blur(28px);
  transition: opacity 0.2s ease;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0));
}

.card.dark .glare {
  background: radial-gradient(circle, rgba(232, 214, 184, 0.38), rgba(255, 255, 255, 0));
}

.rim {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  z-index: 2;
  border: 1px solid rgba(210, 194, 172, 0.45);
  mix-blend-mode: screen;
  transition: box-shadow 0.18s ease-out, border-color 0.2s ease;
}

.card.light .rim {
  border-color: rgba(210, 194, 172, 0.6);
}

.card.dark .rim {
  border-color: rgba(255, 220, 168, 0.35);
}

.grain {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  z-index: 1;
  opacity: 0.06;
  background-image:
    radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px),
    radial-gradient(circle at 80% 30%, rgba(255, 255, 255, 0.07) 0 1px, transparent 1px),
    radial-gradient(circle at 40% 70%, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px);
  background-size: 9px 9px, 11px 11px, 13px 13px;
  mix-blend-mode: soft-light;
}

.sweep {
  position: absolute;
  inset: -20% -80%;
  border-radius: inherit;
  pointer-events: none;
  z-index: 2;
  background: linear-gradient(110deg, rgba(255, 255, 255, 0) 38%, rgba(255, 255, 255, 0.22) 50%, rgba(255, 255, 255, 0) 62%);
  transform: translateX(-120%);
  animation: sweep-in 1.15s ease-out 0.2s both;
}

.dark .grain {
  opacity: 0.08;
}

.dark .sweep {
  background: linear-gradient(110deg, rgba(255, 255, 255, 0) 38%, rgba(255, 230, 190, 0.2) 50%, rgba(255, 255, 255, 0) 62%);
}

@keyframes sweep-in {
  0% {
    transform: translateX(-120%);
    opacity: 0;
  }

  22% {
    opacity: 0.85;
  }

  70% {
    opacity: 0.28;
  }

  100% {
    transform: translateX(120%);
    opacity: 0;
  }
}

.gyroPrompt,
.gyroHint {
  position: absolute;
  inset: auto 16px 16px;
  z-index: 4;
  border-radius: 999px;
  text-align: center;
  font-size: 12px;
  letter-spacing: 0.08em;
