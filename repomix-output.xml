.gyroPrompt {
  border: 1px solid rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.35);
  color: var(--ink);
  padding: 10px 18px;
  text-transform: uppercase;
  cursor: pointer;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.gyroHint {
  margin: 0;
  background: rgba(255, 255, 255, 0.85);
  color: var(--ink);
  padding: 12px 14px;
  border-radius: 12px;
  font-weight: 500;
}
